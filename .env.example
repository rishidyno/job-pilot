# ╔═══════════════════════════════════════════════════════════════════╗
# ║                    JOBPILOT CONFIGURATION                        ║
# ║  Copy this to .env and fill in your values                       ║
# ║  NEVER commit .env to version control!                           ║
# ╚═══════════════════════════════════════════════════════════════════╝

# ───────────────────────────────────────────
# REQUIRED — App won't start without these
# ───────────────────────────────────────────

# Anthropic Claude API key (get from https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# MongoDB connection
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=jobpilot

# ───────────────────────────────────────────
# JOB SEARCH PREFERENCES
# ───────────────────────────────────────────

# Comma-separated target job titles
TARGET_ROLES=Backend Engineer,Full Stack Developer,SDE-1,SDE-2,Software Engineer,Software Developer,Backend Developer

# Experience range in years
TARGET_EXPERIENCE_MIN=1.5
TARGET_EXPERIENCE_MAX=2.5

# Comma-separated target locations
TARGET_LOCATIONS=Bengaluru,Bangalore,Remote,Hyderabad,Noida,Gurgaon,Gurugram

# Comma-separated skills to prioritize in job matching
TARGET_SKILLS=Java,Spring Boot,Node.js,Python,MongoDB,PostgreSQL,React,Docker,Microservices,REST API

# ───────────────────────────────────────────
# TELEGRAM NOTIFICATIONS (optional)
# ───────────────────────────────────────────

# Create a bot via @BotFather on Telegram, paste token here
TELEGRAM_BOT_TOKEN=
# Your personal chat ID (message @userinfobot to get it)
TELEGRAM_CHAT_ID=

# ───────────────────────────────────────────
# JOB PORTAL CREDENTIALS
# Fill in only the portals you want to use
# ───────────────────────────────────────────

LINKEDIN_EMAIL=
LINKEDIN_PASSWORD=

NAUKRI_EMAIL=
NAUKRI_PASSWORD=

WELLFOUND_EMAIL=
WELLFOUND_PASSWORD=

INSTAHYRE_EMAIL=
INSTAHYRE_PASSWORD=

INDEED_EMAIL=
INDEED_PASSWORD=

GLASSDOOR_EMAIL=
GLASSDOOR_PASSWORD=

# ───────────────────────────────────────────
# SCHEDULER SETTINGS
# ───────────────────────────────────────────

# How often to run the job scraper (in hours)
SCRAPE_INTERVAL_HOURS=6

# Master on/off switch for auto-apply
AUTO_APPLY_ENABLED=false

# Default apply mode: "auto" (no review) or "semi" (review first)
AUTO_APPLY_MODE=semi

# Minimum AI match score (0-100) required before auto-applying
MIN_MATCH_SCORE_TO_APPLY=70

# ───────────────────────────────────────────
# ADVANCED / DEVELOPMENT
# ───────────────────────────────────────────

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Run Playwright in headless mode (set false to watch the browser)
PLAYWRIGHT_HEADLESS=true

# Backend server settings
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Rate limiting: seconds to wait between scraping actions
SCRAPE_DELAY_MIN=2
SCRAPE_DELAY_MAX=5
